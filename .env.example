# ─────────────────────────────────────────────
# Supabase
# Auth (email + password) now powers the single
# admin account's sign-in at /admin/login. The
# account itself is NOT created via any signup
# form (none exists) — create it once, manually,
# either in the Supabase dashboard (Authentication
# → Users → Add user) or via the SQL editor, then
# set ADMIN_EMAIL below to that same address.
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────
# Database (Prisma → Supabase Postgres)
# DATABASE_URL  = pooled connection (pgbouncer), used at runtime
# DIRECT_URL    = direct connection, used for migrations
# ─────────────────────────────────────────────
DATABASE_URL=
DIRECT_URL=

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="Job Nest UAE"

# ─────────────────────────────────────────────
# Admin (single admin — no multi-user auth system)
# Must exactly match the email of the one Supabase
# Auth user you create manually. Both middleware.ts
# and every Server Action re-check this on every
# request/submission — a Supabase session for any
# other address is rejected and signed out, even if
# it's otherwise a valid account.
# ─────────────────────────────────────────────
ADMIN_EMAIL=

# ─────────────────────────────────────────────
# Cron (Phase 17) — authorizes the scheduled-job
# auto-publish endpoint (app/api/cron/publish-
# scheduled-jobs/route.ts). Set this to a long
# random string and configure the identical value
# as a Vercel project env var — Vercel's Cron Jobs
# automatically send it as a Bearer token on every
# invocation defined in vercel.json.
# ─────────────────────────────────────────────
CRON_SECRET=
